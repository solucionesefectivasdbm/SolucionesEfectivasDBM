# ============================================================
# SOLUCIONES EFECTIVAS - Variables de entorno
# ============================================================
# Copiar este archivo como .env y completar los valores.
# En Railway estas variables se configuran en el dashboard.
# ============================================================

# Base de datos
# Local:   postgresql+asyncpg://postgres:password@localhost/soluciones_efectivas
# Railway: se configura automaticamente con el plugin PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost/soluciones_efectivas

# Seguridad JWT — CAMBIAR en produccion
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia_esto_en_produccion_usa_secrets_token_hex

# Duracion de tokens
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — URL del frontend (separar multiples con coma)
# Local:      http://localhost:5173
# Produccion: https://tu-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# Entorno: development | production
ENVIRONMENT=development

# Bcrypt cost factor (minimo 12)
BCRYPT_ROUNDS=12

# Puerto (Railway lo inyecta automaticamente)
PORT=8000
